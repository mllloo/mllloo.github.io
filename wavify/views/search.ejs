<!-- it sometimes works search.ejs -->
<!DOCTYPE html>
<html lang="en">
<head><%- include("partials/head", { pageTitle: q ? `"${q}"` : "Search" }) %></head>
<body>

<div class="app-layout">
  <%- include("partials/sidebar", { activePage: "search" }) %>

  <div class="main-area">

    <!-- search page header -->
    <header class="topbar">
      <div class="topbar-left">
        <h1 class="topbar-greeting">Search</h1>
      </div>
      <div class="topbar-right">
        <div class="search-bar-wrap">
          <span class="search-bar-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </span>
          <input class="search-bar-input" id="searchInput" type="text" value="<%= q %>" placeholder="Songs, artists, albums…" autocomplete="off" autofocus />
          <div class="search-dropdown" id="searchDropdown"></div>
        </div>
      </div>
    </header>

    <main class="page-content">

      <!-- empty state before search -->
      <% if (!q) { %>
        <div class="search-empty">
          <div class="search-empty-icon">🎵</div>
          <p>Type something above to find music</p>
        </div>
      <% } else if (songs.length === 0) { %>

        <!-- no results found -->
        <div class="search-empty">
          <div class="search-empty-icon">😕</div>
          <p>No songs found for "<%= q %>"</p>
          <div class="text-muted">Try a different search</div>
        </div>
      <% } else { %>

        <!-- search results -->
        <section class="grid-section">
          <div class="section-header">
            <h2 class="section-title">Results for "<%= q %>"</h2>
            <span class="text-muted"><%= songs.length %> songs</span>
          </div>

          <div class="song-grid">
            <% songs.forEach((song) => { %>
              <article
                class="song-card"
                data-name="<%= song.name %>"
                data-artist="<%= song.artist %>"
                data-audio="<%= song.audio %>"
                data-image="<%= song.image %>"
                data-queue-group="search-results"
              >
                <button class="song-card-like" data-audio="<%= song.audio %>" aria-label="Like">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                </button>

                <div class="song-card-img-wrap">
                  <img src="<%= song.image %>" alt="<%= song.name %>" />
                  <div class="song-card-play-overlay">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>

                <div class="song-card-body">
                  <div class="song-card-name"><%= song.name %></div>
                  <div class="song-card-artist"><%= song.artist %></div>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% } %>
    </main>
  </div>
</div>

<%- include("partials/player") %>

<script src="/app.js"></script>
<script>
  initPage();
</script>
</body>
</html>