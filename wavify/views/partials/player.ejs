<!-- this is also weird player.ejs -->
<!-- blurry background -->
<div class="dynamic-bg" id="dynamic-bg"></div>

<!-- bottom music player -->
<footer class="player" id="player">

  <!-- song info area -->
  <div class="player-info" id="player-info">
    <div class="player-thumb-wrap" id="player-thumb-wrap">
      <img id="player-img" src="data:image/gif;base64,R0lGODlhAQABAIAAAP///wAAACH5BAEAAAAALAAAAAABAAEAAAICRAEAOw==" alt="" />
      <div class="player-thumb-eq" id="player-thumb-eq">
        <div class="eq-bars"><span></span><span></span><span></span><span></span></div>
      </div>
    </div>
    <div class="player-meta">
      <div class="player-title" id="player-title">Nothing Playing</div>
      <div class="player-artist" id="player-artist">—</div>
    </div>
    <button class="player-heart-btn" id="player-heart-btn" onclick="toggleCurrentFavorite()" title="Like">
      <svg width="16" height="16" viewBox="0 0 24 24" id="heart-icon"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
    </button>
  </div>

  <!-- main controls -->
  <div class="player-center">
    <div class="player-buttons">
      <button class="player-btn" id="btn-shuffle" onclick="toggleShuffle()" title="Shuffle">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17 3h4v4h-2V6.41l-4.29 4.3-1.42-1.42L17.59 5H17V3zM3 7h4.59l4 4-1.42 1.41L7.17 9H3V7zm18 10v4h-4v-2h.59l-4.3-4.29 1.42-1.42 4.29 4.3V17H21zM3 17v-2h4.17l10.12-10.12 1.42 1.41L8.59 17H3z"/></svg>
      </button>

      <button class="player-btn" onclick="prevSong()" title="Previous">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/></svg>
      </button>

      <button class="player-btn player-btn-main" id="play-pause-btn" onclick="togglePlay()" title="Play/Pause">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </button>

      <button class="player-btn" onclick="nextSong()" title="Next">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 6h2v12h-2zM6 18l8.5-6L6 6z"/></svg>
      </button>

      <button class="player-btn" id="btn-repeat" onclick="toggleRepeat()" title="Repeat">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/></svg>
      </button>
    </div>

    <!-- progress bar -->
    <div class="player-progress-row">
      <span class="player-time" id="time-current">0:00</span>
      <div class="progress-bar" id="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
        <div class="progress-thumb" id="progress-thumb"></div>
      </div>
      <span class="player-time" id="time-total">0:00</span>
    </div>
  </div>

  <!-- right side controls -->
  <div class="player-right">
    <button class="player-btn" id="btn-queue" onclick="toggleQueue()" title="Queue">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M3 10h14v2H3zm0-4h18v2H3zm0 8h18v2H3zm0 4h14v2H3z"/></svg>
    </button>

    <div class="volume-control">
      <button class="player-btn" onclick="toggleMute()" title="Mute">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" id="volume-icon-svg">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
        </svg>
      </button>
      <div class="volume-bar" id="volume-bar">
        <div class="volume-fill" id="volume-fill"></div>
        <div class="volume-thumb" id="volume-thumb"></div>
      </div>
    </div>
  </div>
</footer>

<!-- queue popup -->
<div class="queue-backdrop" id="queue-backdrop" onclick="toggleQueue()"></div>
<aside class="queue-panel" id="queue-panel">
  <div class="queue-header">
    <span>Up Next</span>
    <button class="queue-close" onclick="toggleQueue()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
    </button>
  </div>
  <div class="queue-list" id="queue-list"></div>
</aside>

<!-- now playing popup -->
<div class="np-modal" id="np-modal">
  <div class="np-backdrop" onclick="closeNpModal()"></div>
  <div class="np-card">
    <button class="np-close" onclick="closeNpModal()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/></svg>
    </button>
    <img id="np-img" src="data:image/gif;base64,R0lGODlhAQABAIAAAP///wAAACH5BAEAAAAALAAAAAABAAEAAAICRAEAOw==" alt="" />
    <div class="np-title" id="np-title">Nothing Playing</div>
    <div class="np-artist" id="np-artist">—</div>
  </div>
</div>

<!-- recent / liked popup -->
<div class="overlay-panel" id="overlay-panel">
  <div class="overlay-backdrop" onclick="closeOverlay()"></div>
  <div class="overlay-card">
    <div class="overlay-header">
      <span id="overlay-title">Songs</span>
      <button onclick="closeOverlay()">✕</button>
    </div>
    <div class="overlay-list" id="overlay-list"></div>
  </div>
</div>

<!-- toast message -->
<div class="toast" id="toast"></div>