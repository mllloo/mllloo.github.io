<aside class="sidebar" id="sidebar">
  <div class="sidebar-inner">

    <div class="sidebar-logo">
      <div class="logo-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
          <path d="M12 3v10.55A4 4 0 1 0 14 17V7h4V3h-6z"/>
        </svg>
      </div>
      <span class="logo-text">Wavify</span>
    </div>

    <nav class="sidebar-nav">
      <p class="sidebar-label">Discover</p>
      <a href="/" class="nav-link <% if (typeof activePage !== 'undefined' && activePage === 'home') { %>active<% } %>" data-page="home">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
        <span>Home</span>
      </a>
      <a href="/search" class="nav-link <% if (typeof activePage !== 'undefined' && activePage === 'search') { %>active<% } %>" data-page="search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
        <span>Search</span>
      </a>

      <p class="sidebar-label" style="margin-top:12px">Library</p>

      <a href="javascript:void(0)" class="nav-link" onclick="showLikedOverlay()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        <span>Liked Songs</span>
      </a>

      <a href="javascript:void(0)" class="nav-link" onclick="showRecentOverlay()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13 3a9 9 0 1 0 8.95 10h-2.02A7 7 0 1 1 13 5v4l5-5-5-5v4z"/></svg>
        <span>Recently Played</span>
      </a>

      <p class="sidebar-label" style="margin-top:12px">Playlists</p>

      <% playlists.forEach((p) => { %>
        <a href="/playlist/<%= encodeURIComponent(p.name) %>"
           class="nav-link nav-link-playlist <% if (typeof activePage !== 'undefined' && activePage === 'playlist:' + p.name) { %>active<% } %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M4 6h12v2H4zm0 5h12v2H4zm0 5h8v2H4zm14-9v10.55A4 4 0 1 0 20 21V7h2V5h-4z"/></svg>
          <span><%= p.name %></span>
          <span class="playlist-count"><%= p.songs.length %></span>
        </a>
      <% }) %>

      <button class="btn-new-playlist" onclick="promptNewPlaylist()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19 11H13V5h-2v6H5v2h6v6h2v-6h6z"/></svg>
        <span>New Playlist</span>
      </button>
    </nav>
  </div>
</aside>

<button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Menu">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3 6h18v2H3zm0 5h18v2H3zm0 5h18v2H3z"/></svg>
</button>