<!-- weird index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head><%- include("partials/head") %></head>
<body>

<div class="app-layout">
  <%- include("partials/sidebar", { activePage: "home" }) %>

  <div class="main-area">

    <!-- top bar -->
    <header class="topbar">
      <div class="topbar-left">
        <h1 class="topbar-greeting" id="greeting">Good evening</h1>
      </div>
      <div class="topbar-right">
        <div class="search-bar-wrap">
          <span class="search-bar-icon">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </span>
          <input class="search-bar-input" id="searchInput" type="text" placeholder="Songs, artists, albums…" autocomplete="off" />
          <div class="search-dropdown" id="searchDropdown"></div>
        </div>
      </div>
    </header>

    <main class="page-content">

      <!-- big carousel at the top -->
      <section class="carousel-section">
        <div class="section-header">
          <h2 class="section-title">🔥 Trending</h2>
          <span class="see-all" onclick="document.getElementById('searchInput').focus()">Search more</span>
        </div>

        <div class="carousel-wrapper" id="hero-carousel">
          <button class="carousel-btn carousel-btn-prev" aria-label="Previous">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          </button>

          <div class="carousel-track">
            <% trending.slice(0, 8).forEach((song, i) => { %>
              <article
                class="carousel-card"
                data-name="<%= song.name %>"
                data-artist="<%= song.artist %>"
                data-audio="<%= song.audio %>"
                data-image="<%= song.image %>"
              >
                <img src="<%= song.image %>" alt="<%= song.name %>" />
                <div class="carousel-play-btn">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <div class="carousel-overlay">
                  <div class="carousel-rank">#<%= i + 1 %> trending</div>
                  <div class="carousel-info">
                    <div class="carousel-song-name"><%= song.name %></div>
                    <div class="carousel-song-artist"><%= song.artist %></div>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>

          <button class="carousel-btn carousel-btn-next" aria-label="Next">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="m8.59 16.59 1.41 1.41 6-6-6-6-1.41 1.41L13.17 12z"/></svg>
          </button>

          <div class="carousel-dots"></div>
        </div>
      </section>

      <!-- first song section -->
      <section class="grid-section">
        <div class="section-header">
          <h2 class="section-title">New Releases</h2>
          <span class="text-muted">Fresh stuff to try</span>
        </div>

        <div class="song-grid">
          <% newReleases.forEach((song) => { %>
            <article
              class="song-card"
              data-name="<%= song.name %>"
              data-artist="<%= song.artist %>"
              data-audio="<%= song.audio %>"
              data-image="<%= song.image %>"
              data-queue-group="new-releases"
            >
              <button class="song-card-like" data-audio="<%= song.audio %>" aria-label="Like">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
              </button>

              <div class="song-card-img-wrap">
                <img src="<%= song.image %>" alt="<%= song.name %>" />
                <div class="song-card-play-overlay">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>

              <div class="song-card-body">
                <div class="song-card-name"><%= song.name %></div>
                <div class="song-card-artist"><%= song.artist %></div>
              </div>
            </article>
          <% }) %>
        </div>
      </section>

      <!-- second song section -->
      <section class="grid-section">
        <div class="section-header">
          <h2 class="section-title">Chill Picks</h2>
          <span class="text-muted">More relaxed songs</span>
        </div>

        <div class="song-grid">
          <% chillPicks.forEach((song) => { %>
            <article
              class="song-card"
              data-name="<%= song.name %>"
              data-artist="<%= song.artist %>"
              data-audio="<%= song.audio %>"
              data-image="<%= song.image %>"
              data-queue-group="chill-picks"
            >
              <button class="song-card-like" data-audio="<%= song.audio %>" aria-label="Like">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
              </button>

              <div class="song-card-img-wrap">
                <img src="<%= song.image %>" alt="<%= song.name %>" />
                <div class="song-card-play-overlay">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>

              <div class="song-card-body">
                <div class="song-card-name"><%= song.name %></div>
                <div class="song-card-artist"><%= song.artist %></div>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    </main>
  </div>
</div>

<%- include("partials/player") %>

<script src="/app.js"></script>
<script>
  initPage();
  initCarousel(document.getElementById('hero-carousel'));

  const hour = new Date().getHours();
  const greeting = document.getElementById('greeting');
  if (greeting) {
    if (hour < 12) greeting.textContent = 'Good morning';
    else if (hour < 18) greeting.textContent = 'Good afternoon';
    else greeting.textContent = 'Good evening';
  }
</script>
</body>
</html>