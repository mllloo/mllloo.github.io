<%- include('partials/head', { title: 'Asteroids' }) %>
<%- include('partials/navbar') %>

<div class="page-wrapper">
    <h1 class="page-title">☄️ Asteroids</h1>
    <p class="page-subtitle">Rocky remnants from the formation of our solar system.</p>

    <% if (data) { %>
        <% if (typeof data === 'object' && !Array.isArray(data)) { %>
            <div class="two-col" style="margin-top:1.5rem;">
                <div>
                    <% if (data.image) { %>
                        <img src="<%= data.image %>" alt="Asteroid Belt" class="planet-img">
                    <% } else { %>
                        <div style="font-size:8rem;text-align:center;padding:2rem;">☄️</div>
                    <% } %>
                </div>
                <div class="info-card">
                    <h2><%= data.name || 'Asteroid Belt' %></h2>
                    <% if (data.description) { %>
                        <p class="pod-explanation"><%= data.description %></p>
                    <% } %>
                    <% Object.keys(data).forEach(k => { %>
                        <% if (k !== 'name' && k !== 'description' && k !== 'image') { %>
                            <div class="info-row">
                                <span class="info-label" style="text-transform:capitalize;"><%= k %></span>
                                <span class="info-value"><%= data[k] %></span>
                            </div>
                        <% } %>
                    <% }); %>
                </div>
            </div>
        <% } else if (Array.isArray(data)) { %>
            <div class="facts-grid">
                <% data.forEach(item => { %>
                    <div class="fact-card">
                        <h3><%= item.name || 'Asteroid' %></h3>
                        <% Object.keys(item).forEach(k => { %>
                            <% if (k !== 'name') { %>
                                <p><strong style="color:#7788bb;"><%= k %>:</strong> <%= item[k] %></p>
                            <% } %>
                        <% }); %>
                    </div>
                <% }); %>
            </div>
        <% } %>
    <% } else { %>
        <div class="two-col" style="margin-top:1.5rem;">
            <div style="font-size:8rem;text-align:center;padding:3rem 0;">☄️</div>
            <div class="info-card">
                <h2>The Asteroid Belt</h2>
                <p class="pod-explanation">
                    The asteroid belt is a torus-shaped region in the Solar System, located roughly between
                    the orbits of Jupiter and Mars. It contains a great many solid, irregularly shaped bodies
                    of many sizes, but much smaller than planets, called asteroids or minor planets.
                </p>
                <div class="info-row"><span class="info-label">Location</span><span class="info-value">Between Mars &amp; Jupiter</span></div>
                <div class="info-row"><span class="info-label">Distance from Sun</span><span class="info-value">2.2 – 3.2 AU</span></div>
                <div class="info-row"><span class="info-label">Known Objects</span><span class="info-value">&gt; 1.1 million</span></div>
                <div class="info-row"><span class="info-label">Largest Body</span><span class="info-value">Ceres (dwarf planet)</span></div>
                <div class="info-row"><span class="info-label">Total Mass</span><span class="info-value">~4% of Earth's Moon</span></div>
            </div>
        </div>

        <h2 style="color:#a0c4ff;margin-top:2.5rem;margin-bottom:1rem;">Notable Asteroids</h2>
        <div class="facts-grid">
            <div class="fact-card"><h3>Ceres</h3><p>The largest object in the asteroid belt and the only dwarf planet located in the inner Solar System. Diameter: ~940 km.</p></div>
            <div class="fact-card"><h3>Vesta</h3><p>The second-largest asteroid by both mass and volume. One of the most massive objects in the asteroid belt. Diameter: ~525 km.</p></div>
            <div class="fact-card"><h3>Pallas</h3><p>The third-largest asteroid in the Solar System by both size and mass. Has an unusually high orbital inclination. Diameter: ~511 km.</p></div>
            <div class="fact-card"><h3>Hygiea</h3><p>The fourth-largest asteroid. Its nearly spherical shape has led to proposals it be reclassified as a dwarf planet. Diameter: ~433 km.</p></div>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>