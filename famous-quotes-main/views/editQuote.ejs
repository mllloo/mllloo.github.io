<%- include('partials/header') %>

<div class="container pb-5" style="max-width:680px;">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Home</a></li>
      <li class="breadcrumb-item active">Edit Quote</li>
    </ol>
  </nav>

  <div class="card border-0 shadow-sm rounded-3">
    <div class="card-header bg-warning text-dark py-3">
      <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Edit Quote</h5>
    </div>
    <div class="card-body p-4">

      <% if (errors.length > 0) { %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% errors.forEach(e => { %><li><%= e %></li><% }) %>
          </ul>
        </div>
      <% } %>

      <form action="/editQuote/<%= quote.quoteId %>" method="POST">
        <div class="mb-3">
          <label class="form-label fw-semibold">Quote <span class="text-danger">*</span></label>
          <textarea name="quote" class="form-control" rows="4" required><%= quote.quote %></textarea>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Author <span class="text-danger">*</span></label>
          <select name="authorId" class="form-select" required>
            <option value="">— Select an author —</option>
            <% authors.forEach(a => { %>
              <option value="<%= a.authorId %>" <%= quote.authorId == a.authorId ? 'selected' : '' %>>
                <%= a.firstName %> <%= a.lastName %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
          <%
            const currentCat  = quote.category || '';
            const catValues   = categories.map(c => c.category);
            const isCustom    = currentCat && !catValues.includes(currentCat);
          %>
          <select name="category" id="catSelect" class="form-select" required>
            <option value="">— Select a category —</option>
            <% categories.forEach(c => { %>
              <option value="<%= c.category %>" <%= currentCat === c.category ? 'selected' : '' %>>
                <%= c.category %>
              </option>
            <% }) %>
            <option value="__custom__" <%= isCustom ? 'selected' : '' %>>+ New category…</option>
          </select>
          <input type="text" id="catCustom" class="form-control mt-2 <%= isCustom ? '' : 'd-none' %>"
                 placeholder="Enter category name"
                 value="<%= isCustom ? currentCat : '' %>">
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Likes</label>
          <input type="number" name="likes" class="form-control" min="0"
                 value="<%= quote.likes %>" style="max-width:150px;">
        </div>

        <div class="d-flex gap-2 mt-4">
          <button type="submit" class="btn btn-warning">
            <i class="bi bi-check-lg me-1"></i>Update Quote
          </button>
          <a href="/" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
const sel = document.getElementById('catSelect');
const cust = document.getElementById('catCustom');
function syncCat() {
  if (sel.value === '__custom__') {
    cust.classList.remove('d-none'); cust.required = true;
    sel.name = ''; cust.name = 'category';
  } else {
    cust.classList.add('d-none'); cust.required = false;
    sel.name = 'category'; cust.name = '_cat';
  }
}
sel.addEventListener('change', syncCat);
<% if (isCustom) { %>syncCat();<% } %>
</script>

<%- include('partials/footer') %>